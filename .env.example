# ==============================================================================
# ZTALeaks - Local Environment Configuration (Template)
# ==============================================================================

# ------------------------------------------------------------------------------
# Infrastructure & Gateway Ports
# ------------------------------------------------------------------------------
BUSINESS_LOGIC_PORT=8080
ENVOY_PORT=8443

# ------------------------------------------------------------------------------
# Splunk Enterprise / Observability
# ------------------------------------------------------------------------------
SPLUNK_PASSWORD=your_secure_splunk_password_here
SPLUNK_HEC_TOKEN=your_splunk_hec_token_uuid_here

# ------------------------------------------------------------------------------
# Database Configurations (MongoDB)
# ------------------------------------------------------------------------------
# Business Database & Seeding
SECURITY_DB_USERNAME=your_security_db_admin_username
SECURITY_DB_PASSWORD=your_security_db_admin_password
SEED_MONGO_URI=mongodb://your_seed_user:your_seed_password@business-db:27017/nuclear_plant_db?authSource=nuclear_plant_db

# MongoDB Initial Setup & Connection
MONGO_INITDB_ROOT_USERNAME=your_mongo_root_username
MONGO_INITDB_ROOT_PASSWORD=your_mongo_root_password
MONGO_URI=mongodb://your_app_user:your_app_password@business-db:27017/nuclear_plant_db?authSource=nuclear_plant_db

# ------------------------------------------------------------------------------
# Security Orchestrator Service
# ------------------------------------------------------------------------------
SECURITY_ORCHESTRATOR_PORT=8081
SECURITY_DB_URI=mongodb://your_security_user:your_security_password@security-db:27017/securitydb?authSource=admin
SECURITY_DB_NAME=securitydb

# ------------------------------------------------------------------------------
# Identity Service & JWKS
# ------------------------------------------------------------------------------
IAM_SERVICE_PORT=8082
IDENTITY_JWKS_URL=http://iam-service:8082/.well-known/jwks.json

# ------------------------------------------------------------------------------
# SMTP (MailHog) - OTP Delivery Service
# ------------------------------------------------------------------------------
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@ztaleaks.local

# ------------------------------------------------------------------------------
# WebAuthn / FIDO2 Authentication (TPM Enrollment)
# ------------------------------------------------------------------------------
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=https://localhost:8443
WEBAUTHN_RP_DISPLAY_NAME=ZTALeaks Nuclear Plant
# Secret per le allowCredentials fittizie deterministiche (anti user-enumeration
# su /login/begin). Solo l'iam-service lo usa.
WEBAUTHN_ENUM_SECRET=change-me-enum-secret
# Secret CONDIVISO orchestrator <-> iam-service/business-logic per firmare in
# HMAC l'header X-Current-User (trust boundary). Deve essere identico nei tre
# servizi, altrimenti l'header firmato viene rifiutato (401).
ORCH_IAM_SHARED_SECRET=change-me-shared-hmac-secret
