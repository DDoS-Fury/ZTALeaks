# Snort rules for internal traffic (Firewall -> Envoy)
# Porta: ENV_ENVOY_PORT (sostituita a runtime dal Dockerfile)

# --- TEST ---
# Ping rule per verificare il funzionamento di Snort
alert icmp any any -> any any (msg:"ZTA: ICMP Test Ping Detected"; itype:8; sid:1000004; rev:1;)

# --- 1. mTLS Violation ---
# Rileva l'assenza del certificato client nel flusso TLS:
# Il messaggio Certificate (tipo 0x0B) con lunghezza 3 e payload "00 00 00" indica
# che il client ha inviato un certificato vuoto (handshake TLS 1.2, RFC 5246 §7.4.6)
alert tcp any any -> any any (msg:"ZTA: mTLS Violation Detected (Missing Client Certificate)"; content:"|0B 00 00 03 00 00 00|"; classtype:protocol-command-decode; sid:2000002; rev:6;)

# --- 2. TLS Downgrade: SSLv3 (version 3.0) ---
# Il record TLS inizia con: Content-Type=0x16 (Handshake), Version=0x03 0x00 (SSLv3)
# depth:3 limita la ricerca ai primi 3 byte del payload per evitare falsi positivi
alert tcp any any -> any ENV_ENVOY_PORT (msg:"ZTA: TLS Downgrade Detected (SSLv3)"; content:"|16 03 00|"; depth:3; classtype:bad-unknown; sid:2000007; rev:2;)

# --- 3. TLS Downgrade: TLS 1.0 (version 3.1) ---
# Record header: Content-Type=0x16, Version=0x03 0x01 (TLS 1.0)
alert tcp any any -> any ENV_ENVOY_PORT (msg:"ZTA: TLS Downgrade Detected (TLS 1.0)"; content:"|16 03 01|"; depth:3; classtype:bad-unknown; sid:2000005; rev:3;)

# --- 4. TLS Downgrade: TLS 1.1 (version 3.2) ---
# Record header: Content-Type=0x16, Version=0x03 0x02 (TLS 1.1)
alert tcp any any -> any ENV_ENVOY_PORT (msg:"ZTA: TLS Downgrade Detected (TLS 1.1)"; content:"|16 03 02|"; depth:3; classtype:bad-unknown; sid:2000008; rev:2;)

# --- 5. Weak Cipher: Deprecated Cipher Suite (RSA-AES-128-CBC-SHA = 0x00 0x2F) ---
# Tipica delle connessioni JA3 inattesi o tool legacy
alert tcp any any -> any ENV_ENVOY_PORT (msg:"ZTA: Weak Cipher Suite Detected (AES-128-CBC-SHA / JA3 Anomaly)"; content:"|00 2F|"; classtype:suspicious-login; sid:2000003; rev:6;)

# --- 6. Weak Cipher: RC4-SHA (0x00 0x05) ---
# RC4 è crittograficamente rotto (RFC 7465 ne vieta l'uso in TLS)
alert tcp any any -> any ENV_ENVOY_PORT (msg:"ZTA: Weak Cipher Suite Detected (RC4-SHA)"; content:"|00 05|"; classtype:bad-unknown; sid:2000009; rev:2;)

# --- 7. Weak Cipher: RC4-MD5 (0x00 0x04) ---
alert tcp any any -> any ENV_ENVOY_PORT (msg:"ZTA: Weak Cipher Suite Detected (RC4-MD5)"; content:"|00 04|"; classtype:bad-unknown; sid:2000010; rev:2;)

# --- 8. Weak Cipher: 3DES-EDE-CBC-SHA (0x00 0x0A) ---
# 3DES è vulnerabile a SWEET32 (CVE-2016-2183); deprecato in RFC 7525
alert tcp any any -> any ENV_ENVOY_PORT (msg:"ZTA: Weak Cipher Suite Detected (3DES-EDE-CBC-SHA)"; content:"|00 0A|"; classtype:bad-unknown; sid:2000011; rev:2;)

# --- 9. Volumetric Network Attack: SYN Flood ---
# Oltre 30 SYN in 2 secondi verso la porta Envoy
alert tcp any any -> any ENV_ENVOY_PORT (msg:"ZTA: SYN Flood - Volumetric Network Attack Detected"; flags:S; detection_filter:track by_dst, count 30, seconds 2; classtype:attempted-dos; sid:2000006; rev:2;)
