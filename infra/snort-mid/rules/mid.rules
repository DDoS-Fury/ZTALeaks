# Snort rules for mid-tier traffic (Envoy -> Security Orchestrator)
# Traffico HTTP chiaro su porta 8081 (confermato da envoy.yaml: http://security-orchestrator:8081)

# --- 1. SQL Injection: UNION-based ---
# Cerca "UNION SELECT" case-insensitive nel payload HTTP (tipico di SQLi in band)
alert tcp any any -> any 8081 (msg:"ZTA: SQL Injection Detected (UNION SELECT)"; flow:to_server,established; content:"UNION"; nocase; content:"SELECT"; nocase; distance:0; within:30; classtype:web-application-attack; sid:3000001; rev:2;)

# --- 2. SQL Injection: OR-based authentication bypass ---
# Pattern "'OR 1=1" e varianti ("' OR '1'='1") usate per bypassare il login
alert tcp any any -> any 8081 (msg:"ZTA: SQL Injection Detected (OR-based Auth Bypass)"; flow:to_server,established; content:"OR"; nocase; content:"1=1"; nocase; distance:0; within:10; classtype:web-application-attack; sid:3000002; rev:2;)

# --- 3. SQL Injection: DROP TABLE ---
# Comando distruttivo; anche nelle varianti "DROP TABLE" e "DROP DATABASE"
alert tcp any any -> any 8081 (msg:"ZTA: SQL Injection Detected (DROP statement)"; flow:to_server,established; content:"DROP"; nocase; content:"TABLE"; nocase; distance:0; within:20; classtype:web-application-attack; sid:3000003; rev:2;)

# --- 4. SQL Injection: commento SQL (--) ---
# Il doppio trattino "-- " è il commento SQL standard; spesso usato per troncare query
alert tcp any any -> any 8081 (msg:"ZTA: SQL Injection Detected (SQL Comment --)"; flow:to_server,established; content:"--"; classtype:web-application-attack; sid:3000004; rev:2;)

# --- 5. SQL Injection: stacked queries (;) ---
# Il punto e virgola permette l'esecuzione di query multiple consecutive
alert tcp any any -> any 8081 (msg:"ZTA: SQL Injection Detected (Stacked Queries)"; flow:to_server,established; content:"'; "; classtype:web-application-attack; sid:3000005; rev:2;)

# --- 6. XSS: tag <script> ---
# Injection del tag <script> nel payload (stored o reflected XSS)
alert tcp any any -> any 8081 (msg:"ZTA: XSS Detected (<script> tag)"; flow:to_server,established; content:"<script"; nocase; classtype:web-application-attack; sid:3000006; rev:2;)

# --- 7. XSS: javascript: pseudo-protocol ---
# Usato in attributi href/src per eseguire codice JS senza <script>
alert tcp any any -> any 8081 (msg:"ZTA: XSS Detected (javascript: URI)"; flow:to_server,established; content:"javascript:"; nocase; classtype:web-application-attack; sid:3000007; rev:2;)

# --- 8. XSS: event handler onerror ---
# onerror= è un vettore XSS molto comune in tag <img> e simili
alert tcp any any -> any 8081 (msg:"ZTA: XSS Detected (onerror event handler)"; flow:to_server,established; content:"onerror="; nocase; classtype:web-application-attack; sid:3000008; rev:2;)

# --- 9. XSS: event handler onload ---
# onload= viene usato su <body>, <img>, <iframe> per eseguire JS al caricamento
alert tcp any any -> any 8081 (msg:"ZTA: XSS Detected (onload event handler)"; flow:to_server,established; content:"onload="; nocase; classtype:web-application-attack; sid:3000009; rev:2;)
